{
  "name": "hatebu-kkeisuke-2",
  "version": "1.0.0",
  "description": "kkeisuke's はてなブックマーク まとめサイトジェネレータ",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "cli:dev": "dotenvx run -- ts-node src/cli.ts",
    "test": "dotenvx run -- jest",
    "test:ci": "jest --silent",
    "lint": "prettier --write . --loglevel warn && eslint ./ --ext .js,.ts --fix",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/cli.ts --bundle --platform=node --target=node24.15.0 --minify --outfile=dist/cli.js"
  },
  "license": "MIT",
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.64.0",
    "@types/jest": "^28.1.8",
    "@types/node": "^16.11.56",
    "@typescript-eslint/eslint-plugin": "^5.35.1",
    "@typescript-eslint/parser": "^5.35.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.22.0",
    "eslint-config-prettier": "^8.5.0",
    "nock": "^13.2.9",
    "prettier": "^2.7.1",
    "ts-jest": "^28.0.8",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.2"
  },
  "dependencies": {
    "@octokit/rest": "^19.0.4",
    "algoliasearch": "^4.14.2",
    "cac": "^6.7.12",
    "hatebu-mydata-parser": "^1.0.0"
  }
}
